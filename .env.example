# Application
NODE_ENV=production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Docker host configuration ─────────────────────────────────────────────────
# Directory on the HOST where persistent data is stored.
# Defaults to ./data (relative to docker-compose.yml) if not set.
# Use an absolute path for production, e.g. /opt/devotional/data
HOST_DATA_DIR=./data

# Port the web app is exposed on the host (default: 3000)
WEB_PORT=3000

# Data paths (used INSIDE Docker containers — do not change unless you also
# update the volume mounts in docker-compose.yml)
DB_PATH=/data/db/devotional.db
PROJECTS_DIR=/data/projects
LOGS_DIR=/data/logs
BROWSER_PROFILES_DIR=/data/browser-profiles
DOWNLOADS_DIR=/data/downloads

# Worker settings
WORKER_POLL_INTERVAL_MS=2000
WORKER_MAX_CONCURRENT_JOBS=1
WORKER_ID=worker-1

# Browser settings
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_SLOW_MO=100
PLAYWRIGHT_TIMEOUT_MS=60000
PLAYWRIGHT_NAV_TIMEOUT_MS=30000
