{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "module": "commonjs",
    "moduleResolution": "node",
    "jsx": "react",
    "target": "ES2020"
  },
  "include": ["worker/**/*.ts", "src/lib/**/*.ts", "src/types/**/*.ts"],
  "exclude": ["node_modules", ".next", "src/app/**/*.tsx", "src/components/**/*.tsx"]
}
