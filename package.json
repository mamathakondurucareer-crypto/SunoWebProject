    "test:suno": "node --require tsx/cjs --test 'src/lib/suno/__tests__/**/*.test.ts'",
    "test:eval": "node --require tsx/cjs --test 'src/lib/chatgpt-eval/__tests__/**/*.test.ts'",
    "test:scene": "node --require tsx/cjs --test 'src/lib/scene-plan/__tests__/**/*.test.ts'",
    "test:prompts": "node --require tsx/cjs --test 'src/lib/prompt-refine/__tests__/**/*.test.ts'",
    "test:scheduler": "node --require tsx/cjs --test 'src/lib/scheduler/__tests__/**/*.test.ts'"
