    "@types/uuid": "^10.0.0",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.7.2",
    "tailwindcss": "^3.4.17",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20",
    "tsx": "^4.19.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.29"
  }
